{
  "manifest_version": 3,
  "name": "Festag — Tagro",
  "version": "0.9.5",
  "description": "Tagro Schreibhilfe überall im Browser und Live-Feedback auf Projekt-Vorschauen.",
  "permissions": ["storage", "activeTab", "scripting", "cookies"],
  "host_permissions": [
    "https://festag.app/*",
    "https://www.festag.app/*",
    "http://localhost:3000/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Festag Tagro",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "externally_connectable": {
    "matches": [
      "https://festag.app/*",
      "https://www.festag.app/*",
      "http://localhost:3000/*"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://festag.app/*",
        "https://www.festag.app/*",
        "http://localhost:3000/*"
      ],
      "js": ["festag-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["writing-assistant.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
