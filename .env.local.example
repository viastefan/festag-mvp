# Supabase — Festag project xsdkoepwuvpuroijjain
# Dashboard: https://supabase.com/dashboard/project/xsdkoepwuvpuroijjain/settings/api
# CLI: npm run supabase:login && npm run supabase:link && npm run db:push
# Verify: npm run check:supabase
NEXT_PUBLIC_SUPABASE_URL=https://xsdkoepwuvpuroijjain.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...dein-anon-key

# Service Role — SERVER ONLY, never NEXT_PUBLIC_, never commit real value.
# Must be the JWT service_role secret (starts with eyJ), NOT sb_secret_*.
# Dashboard → Settings → API → service_role → Reveal
SUPABASE_SERVICE_ROLE_KEY=eyJ...dein-service-role-jwt

# ── Tagro AI provider ────────────────────────────────────────────────
# Tagro runs on the Claude API (Anthropic) as its PRIMARY brain whenever
# ANTHROPIC_API_KEY is set. Provider priority across the app:
#   Claude (Anthropic) → Gemini → MiniMax (emergency, env-only)
# Set this locally and in Vercel to put Tagro on Claude.
ANTHROPIC_API_KEY=sk-ant-...
TAGRO_CLAUDE_MODEL=claude-sonnet-4-6

# Fallback: Gemini (Google AI Studio) — server-side only
GEMINI_API_KEY=
TAGRO_GEMINI_MODEL=gemini-3.5-flash

# Emergency fallback only — server-side only. No hardcoded keys in source.
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7
OPENAI_API_KEY=

# Enjyn Payment API — server-side only (Key aus Enjyn Stammdaten)
ENJYN_API_KEY=dein-enjyn-api-key
