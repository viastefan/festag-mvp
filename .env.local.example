# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-key

# Supabase Service Role (server-side only — fuer AI-Decompose etc.)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Tagro AI provider ────────────────────────────────────────────────
# Tagro runs on the Claude API (Anthropic) as its PRIMARY brain whenever
# ANTHROPIC_API_KEY is set. Provider priority across the app:
#   Claude (Anthropic) → Gemini → MiniMax (emergency, env-only)
# Set this locally and in Vercel to put Tagro on Claude.
ANTHROPIC_API_KEY=sk-ant-...
TAGRO_CLAUDE_MODEL=claude-sonnet-4-6

# Fallback: Gemini (Google AI Studio) — server-side only
GEMINI_API_KEY=
TAGRO_GEMINI_MODEL=gemini-3.5-flash

# Emergency fallback only — server-side only. No hardcoded keys in source.
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7
OPENAI_API_KEY=

# Enjyn Payment API — server-side only (Key aus Enjyn Stammdaten)
ENJYN_API_KEY=dein-enjyn-api-key
