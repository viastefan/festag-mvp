{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Open Festag Dashboard (Simple Browser)",
      "type": "shell",
      "command": "echo ${input:festagSimpleBrowser}",
      "presentation": {
        "reveal": "never",
        "echo": false,
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "festagSimpleBrowser",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": ["http://localhost:3000/dashboard"]
    }
  ]
}
